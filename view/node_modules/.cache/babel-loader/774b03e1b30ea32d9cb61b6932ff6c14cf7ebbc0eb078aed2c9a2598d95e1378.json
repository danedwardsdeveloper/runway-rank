{"ast":null,"code":"export default {\n  data() {\n    return {\n      baseUrl: process.env.NODE_ENV === \"development\" ? \"http://localhost:3000\" : \"http://www.runwayrank.com\",\n      nextPair: [{}, {}],\n      isDisabled: true,\n      isLoggedIn: false\n    };\n  },\n  mounted() {\n    this.fetchInitialPair();\n  },\n  methods: {\n    async fetchInitialPair() {\n      const response = await fetch('http://localhost:3000/api/items/get-next-pair');\n      const data = await response.json();\n      this.nextPair = data;\n    },\n    async handleClick(itemIndex) {\n      let postData = {};\n      if (itemIndex === 0) {\n        postData.winnerID = this.nextPair[0].id;\n        postData.loserID = this.nextPair[1].id;\n      } else {\n        postData.winnerID = this.nextPair[1].id;\n        postData.loserID = this.nextPair[0].id;\n      }\n      const response = await fetch('http://localhost:3000/api/items/post-ratings', {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json'\n        },\n        body: JSON.stringify(postData)\n      });\n      const result = await response.json();\n      if (!response.ok) {\n        console.log(result);\n      }\n      this.fetchInitialPair();\n    }\n  }\n};","map":{"version":3,"names":["data","baseUrl","process","env","NODE_ENV","nextPair","isDisabled","isLoggedIn","mounted","fetchInitialPair","methods","response","fetch","json","handleClick","itemIndex","postData","winnerID","id","loserID","method","headers","body","JSON","stringify","result","ok","console","log"],"sources":["/Users/dan/Documents/GitHub/runway-rank/view/src/App.vue"],"sourcesContent":["<template>\n  <main>\n    <h1>Runway Rank</h1>\n    <p v-if=\"isLoggedIn\">Vote for your favourite</p>\n    <p v-else>\n      <a href=\"\">Create an account</a>\n      or <a href=\"\"> log in</a> to vote for your favourite\n    </p>\n    <p>Cast votes for all pairs to see the\n      <a href=\"\" :class=\"{ disabled: isDisabled }\">top ten lewks</a>\n    </p>\n    <div class=\"container\">\n\n      <button @click=\"handleClick(0)\" :disabled=\"isDisabled\">\n        <div class=\"image-container\">\n          <img :src=\"`${baseUrl}${nextPair[0].image_path}`\" alt=\"Image\" />\n        </div>\n        <h2>{{ nextPair[0].name }}</h2>\n      </button>\n\n      <button @click=\"handleClick(1)\" :disabled=\"isDisabled\">\n        <div class=\"image-container\">\n          <img :src=\"`${baseUrl}${nextPair[1].image_path}`\" alt=\"Image\" />\n        </div>\n        <h2>{{ nextPair[1].name }}</h2>\n      </button>\n\n    </div>\n  </main>\n</template>\n\n<script>\nexport default {\n  data() {\n    return {\n      baseUrl: process.env.NODE_ENV === \"development\" ? \"http://localhost:3000\" : \"http://www.runwayrank.com\",\n      nextPair: [{}, {}],\n      isDisabled: true,\n      isLoggedIn: false\n    };\n  },\n\n  mounted() {\n    this.fetchInitialPair();\n  },\n\n  methods: {\n    async fetchInitialPair() {\n      const response = await fetch('http://localhost:3000/api/items/get-next-pair');\n      const data = await response.json();\n      this.nextPair = data;\n    },\n\n    async handleClick(itemIndex) {\n      let postData = {};\n\n      if (itemIndex === 0) {\n        postData.winnerID = this.nextPair[0].id;\n        postData.loserID = this.nextPair[1].id;\n      } else {\n        postData.winnerID = this.nextPair[1].id;\n        postData.loserID = this.nextPair[0].id;\n      }\n\n      const response = await fetch('http://localhost:3000/api/items/post-ratings', {\n        method: 'POST',\n        headers: { 'Content-Type': 'application/json' },\n        body: JSON.stringify(postData)\n      });\n\n      const result = await response.json();\n      if (!response.ok) {\n        console.log(result);\n      }\n\n      this.fetchInitialPair()\n    }\n  }\n};\n</script>\n\n<style scoped lang=\"less\">\nmain {\n  text-align: center;\n  font-family: Arial, sans-serif;\n  box-sizing: border-box;\n}\n\np {\n  font-size: 16px;\n  margin: 0;\n  line-height: 1.8;\n}\n\na {\n  &:visited {\n    color: navy;\n  }\n\n  &.disabled:hover {\n    cursor: not-allowed;\n  }\n}\n\n.container {\n  display: flex;\n  justify-content: center;\n\n  button {\n    width: 300px;\n    height: 400px;\n    margin: 30px;\n    background-color: #EEE;\n    border: none;\n    outline: 4px solid transparent;\n    display: flex;\n    flex-direction: column;\n    justify-content: flex-end;\n    align-items: center;\n\n    &:hover {\n      outline-color: lightgreen;\n    }\n\n    &:active {\n      transform: scale(0.98);\n      box-shadow: 3px 2px 22px 1px rgba(0, 0, 0, 0.24);\n    }\n\n    &:disabled {\n      cursor: not-allowed;\n\n      &:hover {\n        outline-color: grey;\n      }\n\n      &:active {\n        transform: scale(1);\n        box-shadow: none;\n      }\n    }\n  }\n}\n\n.image-container {\n  width: 100%;\n  height: auto;\n  overflow: hidden;\n  padding: 10px;\n\n  img {\n    max-width: 100%;\n    height: auto;\n    display: block;\n  }\n}\n</style>\n"],"mappings":"AAgCA,eAAe;EACbA,IAAIA,CAAA,EAAG;IACL,OAAO;MACLC,OAAO,EAAEC,OAAO,CAACC,GAAG,CAACC,QAAO,KAAM,aAAY,GAAI,uBAAsB,GAAI,2BAA2B;MACvGC,QAAQ,EAAE,CAAC,CAAC,CAAC,EAAE,CAAC,CAAC,CAAC;MAClBC,UAAU,EAAE,IAAI;MAChBC,UAAU,EAAE;IACd,CAAC;EACH,CAAC;EAEDC,OAAOA,CAAA,EAAG;IACR,IAAI,CAACC,gBAAgB,CAAC,CAAC;EACzB,CAAC;EAEDC,OAAO,EAAE;IACP,MAAMD,gBAAgBA,CAAA,EAAG;MACvB,MAAME,QAAO,GAAI,MAAMC,KAAK,CAAC,+CAA+C,CAAC;MAC7E,MAAMZ,IAAG,GAAI,MAAMW,QAAQ,CAACE,IAAI,CAAC,CAAC;MAClC,IAAI,CAACR,QAAO,GAAIL,IAAI;IACtB,CAAC;IAED,MAAMc,WAAWA,CAACC,SAAS,EAAE;MAC3B,IAAIC,QAAO,GAAI,CAAC,CAAC;MAEjB,IAAID,SAAQ,KAAM,CAAC,EAAE;QACnBC,QAAQ,CAACC,QAAO,GAAI,IAAI,CAACZ,QAAQ,CAAC,CAAC,CAAC,CAACa,EAAE;QACvCF,QAAQ,CAACG,OAAM,GAAI,IAAI,CAACd,QAAQ,CAAC,CAAC,CAAC,CAACa,EAAE;MACxC,OAAO;QACLF,QAAQ,CAACC,QAAO,GAAI,IAAI,CAACZ,QAAQ,CAAC,CAAC,CAAC,CAACa,EAAE;QACvCF,QAAQ,CAACG,OAAM,GAAI,IAAI,CAACd,QAAQ,CAAC,CAAC,CAAC,CAACa,EAAE;MACxC;MAEA,MAAMP,QAAO,GAAI,MAAMC,KAAK,CAAC,8CAA8C,EAAE;QAC3EQ,MA